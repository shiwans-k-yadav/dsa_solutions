class Solution {
public:
    bool rotateString(string s, string goal) {
        if(s.length()!=goal.length()){
            return false;
        }

        string temp = s+s;
        return temp.find(goal)!=string::npos;
        
    //Agar substring mil jaati hai → uska starting index return hota hai.
    //Agar nahi milti → string::npos return hota hai.
    }
};
